# =============================================================================
# LOCKIFY - Environment Variables
# =============================================================================
# Copy this file: cp .env.example .env
# NEVER commit .env to git — it contains secrets
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL) - All credentials stored in user_credentials table
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lockify
DB_USER=lockify
DB_PASSWORD=change_me_strong_db_password

# -----------------------------------------------------------------------------
# REDIS - Rate limiting, account lock cache, token blacklist
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# JWT - Access tokens (short-lived, stateless)
# Generate: openssl rand -base64 64
# MINIMUM 32 characters. Production: use 64+ random bytes.
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64
JWT_ACCESS_EXPIRY=15
JWT_REFRESH_EXPIRY=7

# -----------------------------------------------------------------------------
# PASSWORD SECURITY - Pepper adds server-side secret before BCrypt
# Generate: openssl rand -base64 32
# If DB is stolen, attacker still needs this pepper to crack passwords.
# -----------------------------------------------------------------------------
PASSWORD_PEPPER=change_me_generate_with_openssl_rand_base64_32
BCRYPT_STRENGTH=12

# -----------------------------------------------------------------------------
# PHASE 2 - Account Security
# -----------------------------------------------------------------------------
LOCKIFY_MAX_FAILED_ATTEMPTS=5
LOCKIFY_LOCK_DURATION_MINUTES=30
LOCKIFY_EMAIL_VERIFICATION_HOURS=24
LOCKIFY_PASSWORD_RESET_HOURS=1
LOCKIFY_PASSWORD_HISTORY_COUNT=5
LOCKIFY_PASSWORD_EXPIRY_DAYS=90

# -----------------------------------------------------------------------------
# PHASE 4 - Rate Limiting
# -----------------------------------------------------------------------------
LOCKIFY_RATELIMIT_ENABLED=true
LOCKIFY_RATELIMIT_REQUESTS_PER_MINUTE=10

# -----------------------------------------------------------------------------
# PHASE 5 - OAuth2 (optional — leave empty to disable)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# EMAIL (future — SMTP for verification/reset emails)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# CORS - Frontend origins (comma-separated)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# -----------------------------------------------------------------------------
# [ ] JWT_SECRET is unique random 64+ chars
# [ ] PASSWORD_PEPPER is set and backed up securely
# [ ] DB_PASSWORD is strong
# [ ] HTTPS enabled (reverse proxy / load balancer)
# [ ] Redis has password in production
# [ ] OAuth secrets only if using social login
